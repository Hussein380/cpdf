# ─── Site ─────────────────────────────────────────────────────────────────────
# Publicly visible URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://cpdforum.org

# ─── Analytics (optional) ─────────────────────────────────────────────────────
# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Contact Form (optional) ──────────────────────────────────────────────────
# If you add a backend API route for the contact form, add credentials here.
# Example using Resend for email delivery:
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# CONTACT_FORM_TO=info@cpdforum.org

# ─── CMS / Content (optional, for blog phase) ─────────────────────────────────
# SANITY_PROJECT_ID=
# SANITY_DATASET=production
# SANITY_API_TOKEN=
